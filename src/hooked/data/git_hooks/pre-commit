#!/usr/bin/env sh
# Global pre-commit hook managed by "hooked"
# Runs global checks, avoids recursion, and falls back to repo-local hooks.

set -eu

# repo paths
GIT_DIR="$(git rev-parse --git-dir)"
REPO_ROOT="$(git rev-parse --show-toplevel)"
LOCAL_HOOK="$GIT_DIR/hooks/pre-commit"

# set this preemptively for gitleaks if used
export GITLEAKS_CONFIG="${HOME}/.config/hooked/config/.gitleaks.toml"

log() { printf '[hooked] %s\n' "$*"; }

log "Running global pre-commit checks..."
log "pre-commit version: $(pre-commit --version || echo 'not installed')"

# Update global config if available
if [ -d "${HOME}/.config/hooked/config" ]; then
  (cd "${HOME}/.config/hooked/config" && pre-commit autoupdate)
fi

# Skip duplicate hooks from repo config
if [ -f "$REPO_ROOT/.pre-commit-config.yaml" ]; then
  duplicated_hooks=$(hooked list-duplicate-hooks "$REPO_ROOT/.pre-commit-config.yaml")
  [ -n "$duplicated_hooks" ] && log "Duplicated hooks in repo: $duplicated_hooks"
  export SKIP="${duplicated_hooks:-}"
fi

# Run global hooks on staged files
staged_files=$(git diff --cached --name-only --diff-filter=ACM)
if [ -n "$staged_files" ]; then
  pre-commit run \
    --config "${HOME}/.config/hooked/config/.pre-commit-config.yaml" \
    --files "${staged_files}" || exit $?
fi

unset SKIP
unset GITLEAKS_CONFIG
log "Finished running global hooks."

# --- Helper: resolve symlinks to avoid recursion ---
resolve_path() {
  if command -v realpath >/dev/null 2>&1; then
    realpath "$1" 2>/dev/null || printf "%s" "$1"
  elif command -v python3 >/dev/null 2>&1; then
    python3 -c 'import os,sys; print(os.path.realpath(sys.argv[1]))' "$1" 2>/dev/null || printf "%s" "$1"
  else
    printf "%s" "$1"
  fi
}

THIS="$(resolve_path "$0")"
LOCAL_RESOLVED="$(resolve_path "$LOCAL_HOOK")"

# Run repo-local hook if it exists and isn't this one
if [ -x "$LOCAL_HOOK" ] && [ "$LOCAL_RESOLVED" != "$THIS" ]; then
  log "Found repo-local pre-commit hook → running it..."
  exec "$LOCAL_HOOK" "$@"
fi

# If repo has .pre-commit-config.yaml but hooks aren't installed, install + run
if [ -f "$REPO_ROOT/.pre-commit-config.yaml" ]; then
  if command -v pre-commit >/dev/null 2>&1; then
    log ".pre-commit-config.yaml detected; ensuring hooks are installed..."
    hooks_path="$(git config --global core.hooksPath || true)"

    git config --unset --global core.hooksPath || true
    pre-commit install
    [ -n "${hooks_path}" ] && git config --global core.hooksPath "${hooks_path}"

    log "Running repo-local hooks..."
    exec pre-commit run --hook-stage pre-commit
  else
    log "ERROR: .pre-commit-config.yaml found but 'pre-commit' is not installed."
    log "Install it with: pip install --upgrade pre-commit"
    exit 1
  fi
fi

log "No repo-local hook or pre-commit config found. Done."
exit 0
